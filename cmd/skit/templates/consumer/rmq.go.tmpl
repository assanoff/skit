package {{.Pkg}}

import (
	"github.com/assanoff/skit/broker/rabbitmq"
	"github.com/assanoff/skit/worker"

	"{{.Module}}/internal/app/config"
)

// Runnable builds the RabbitMQ consumer for this handler. Every knob is spelled
// out here (not hidden behind rabbitmq.New) so you can override it freely —
// exchange kind, routing keys, concurrency, name — or drop rabbitmq.NewConsumer
// entirely and build your own topology/loop over the AMQP client, still calling
// c.Handle. The handler in {{.Pkg}}.go stays broker-agnostic; this file is the
// only transport-specific one.
func (c *Consumer) Runnable(conn *rabbitmq.Conn, opts config.ConsumerOpts) (worker.Runnable, error) {
	return rabbitmq.NewConsumer(conn, c.log, rabbitmq.ConsumerConfig{
		Queue:       opts.Group,
		Exchange:    opts.Topic,
		RoutingKeys: opts.Filters,
		Concurrency: opts.Concurrency,
		Name:        "{{.Pkg}}-consumer",
		// ExchangeKind defaults to "topic"; set it for a direct/fanout exchange.
	}, c.Handle)
}
