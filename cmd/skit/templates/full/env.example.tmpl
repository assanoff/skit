# Copy to .env for local development. Real environment variables always win.
# These map to the go-flags options in internal/app/config/opts.go.
SERVICE_NAME={{.Name}}
APP_ENV=development
LOG_LEVEL=info

# The REST and status servers each start iff their *_ADDR is set; clear an
# address (e.g. HTTP_ADDR=) to turn that server off.
HTTP_ADDR=:8080
HTTP_REQUEST_TIMEOUT=30s
HTTP_SHUTDOWN_TIMEOUT=10s

# Status server: pprof + metrics + health on its own internal port.
DEBUG_ADDR=localhost:6060

# gRPC server + gateway. OFF by default (empty GRPC_ADDR). `skit add grpc` wires
# the server, the REST gateway and the OpenAPI docs; turn the stack on together:
#   GRPC_ADDR=:9090      # gRPC listen address (empty disables the gRPC server)
#   GRPC_GATEWAY=true    # mount the REST<->gRPC proxy (/v1/...) on the HTTP server
#   GRPC_DOCS=true       # serve the Swagger UI at /docs (+ /openapi.json)
#   GRPC_REFLECTION=true # gRPC server reflection (grpcurl / Postman)
GRPC_ADDR=

DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost:5432
DB_NAME={{.Snake}}
DB_SCHEMA=public
# Off for local dev (local Postgres has no TLS). Set DB_TLS=true in production —
# the service refuses to start with APP_ENV=production and TLS off.
DB_TLS=false

# Tracing is off by default; enable with a collector on OTEL_ENDPOINT.
OTEL_ENABLED=false
OTEL_ENDPOINT=localhost:4317
OTEL_INSECURE=true
OTEL_PROBABILITY=1.0

# RabbitMQ + transactional outbox. OFF by default (needs external infra). When
# enabled, the relay/sweeper/cleaner workers run and domain events are delivered.
BROKER_ENABLED=false
BROKER_HOST=localhost
BROKER_PORT=5672
BROKER_USER=guest
BROKER_PASSWORD=guest

# Redis. OFF by default (needs external infra). Enable it for features that need
# it, e.g. a distributed cron lock (`skit add cron --lock redis`).
REDIS_ENABLED=false
REDIS_ADDR=localhost:6379
REDIS_DB=0
