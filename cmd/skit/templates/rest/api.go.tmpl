// Package {{.Pkg}} is the REST transport layer for the {{.Pkg}} module. Handlers
// are skit rest.HandlerFunc values: they decode/validate input, call the
// Core, and return a ResponseEncoder (a DTO or an *errs.Error).
package {{.Pkg}}

import (
	"context"
	"net/http"
	"net/url"
	"strconv"
	"strings"

	"github.com/google/uuid"

	"github.com/assanoff/skit/errs"
	"github.com/assanoff/skit/order"
	"github.com/assanoff/skit/page"
	"github.com/assanoff/skit/query"
	"github.com/assanoff/skit/rest"

	{{.Pkg}}core "{{.Module}}/core/{{.Pkg}}"
)

// Handler exposes {{.Pkg}} endpoints.
type Handler struct {
	core *{{.Pkg}}core.Core
}

// New builds a Handler.
func New(core *{{.Pkg}}core.Core) *Handler {
	return &Handler{core: core}
}

// Routes registers the {{.Pkg}} endpoints through the handle seam, so this
// transport does not depend on the router type — the server's Install function
// passes router.HandleApp. Reads are public; each write passes authMW (e.g.
// JWT auth + RBAC, as rest.MidFunc) so it requires authorization when auth is
// enabled, and is unguarded otherwise.
func (h *Handler) Routes(handle rest.Handle, authMW ...rest.MidFunc) {
	handle("GET /{{.Plural}}", h.query)
	// Keyset (cursor) pagination — the insert-stable, depth-cheap alternative to
	// ?page/?rows offset paging. The literal /cursor segment is matched ahead of
	// /{id} by net/http's pattern precedence.
	handle("GET /{{.Plural}}/cursor", h.queryCursor)
	handle("GET /{{.Plural}}/{id}", h.queryByID)

	handle("POST /{{.Plural}}", h.create, authMW...)
	handle("PUT /{{.Plural}}/{id}", h.update, authMW...)
	handle("DELETE /{{.Plural}}/{id}", h.delete, authMW...)
}

// create creates a single {{.Pkg}}.
func (h *Handler) create(ctx context.Context, r *http.Request) rest.ResponseEncoder {
	var req Create{{.Type}}Req
	if err := rest.Decode(r, &req); err != nil {
		return errs.From(err)
	}

	{{.Recv}}, err := h.core.Create(ctx, {{.Pkg}}core.New{{.Type}}{Name: req.Name, Description: req.Description})
	if err != nil {
		return errs.From(err)
	}
	return rest.JSONStatus(toResponse({{.Recv}}), http.StatusCreated)
}

// query lists one page of {{.Plural}} (?page, ?rows), optionally narrowed by the
// filter params (?name, ?description) and ordered by ?order_by (e.g. "name,DESC";
// default created_at DESC). Count uses the same filter so the total matches.
func (h *Handler) query(ctx context.Context, r *http.Request) rest.ResponseEncoder {
	q := r.URL.Query()
	pg, err := page.Parse(q.Get("page"), q.Get("rows"))
	if err != nil {
		return errs.New(errs.InvalidArgument, err)
	}
	by, err := order.Parse({{.Pkg}}core.SortableFields, q.Get("order_by"), {{.Pkg}}core.DefaultOrder)
	if err != nil {
		return errs.New(errs.InvalidArgument, err)
	}
	filter := parseFilter(q)

	{{.Recv}}s, err := h.core.Query(ctx, filter, by, pg)
	if err != nil {
		return errs.From(err)
	}
	total, err := h.core.Count(ctx, filter)
	if err != nil {
		return errs.From(err)
	}
	return query.NewResult(toResponseList({{.Recv}}s), total, pg)
}

// queryCursor lists {{.Plural}} with keyset (cursor) pagination: ?cursor=<token>
// (the opaque token from a prior page's next, empty for the first page), ?limit=N,
// and the same ?name/?description filter. It returns a query.CursorResult with the
// items and the next-page token. Forward-only — prev is not emitted.
func (h *Handler) queryCursor(ctx context.Context, r *http.Request) rest.ResponseEncoder {
	q := r.URL.Query()
	limit, _ := strconv.Atoi(q.Get("limit")) // 0/invalid -> NewCursor applies the default
	cur := page.NewCursor(q.Get("cursor"), limit)
	if _, err := cur.Key(); err != nil {
		return errs.New(errs.InvalidArgument, err) // malformed cursor token -> 400
	}
	filter := parseFilter(q)

	{{.Recv}}s, next, err := h.core.QueryByCursor(ctx, filter, cur)
	if err != nil {
		return errs.From(err)
	}
	return query.NewCursorResult(toResponseList({{.Recv}}s), next, "")
}

// parseFilter reads the optional listing filter from the query string: ?name and
// ?description, each a case-insensitive substring. Absent params leave that field
// nil (not applied).
func parseFilter(q url.Values) {{.Pkg}}core.QueryFilter {
	var f {{.Pkg}}core.QueryFilter
	if name := strings.TrimSpace(q.Get("name")); name != "" {
		f.Name = &name
	}
	if desc := strings.TrimSpace(q.Get("description")); desc != "" {
		f.Description = &desc
	}
	return f
}

// queryByID returns one {{.Pkg}} by id.
func (h *Handler) queryByID(ctx context.Context, r *http.Request) rest.ResponseEncoder {
	id, err := uuid.Parse(r.PathValue("id"))
	if err != nil {
		return errs.Newf(errs.InvalidArgument, "invalid id %q", r.PathValue("id"))
	}

	{{.Recv}}, err := h.core.QueryByID(ctx, id)
	if err != nil {
		return errs.From(err)
	}
	return toResponse({{.Recv}}) // Response implements rest.ResponseEncoder
}

// update applies a partial update to a {{.Pkg}}.
func (h *Handler) update(ctx context.Context, r *http.Request) rest.ResponseEncoder {
	id, err := uuid.Parse(r.PathValue("id"))
	if err != nil {
		return errs.Newf(errs.InvalidArgument, "invalid id %q", r.PathValue("id"))
	}

	var req Update{{.Type}}Req
	if err := rest.Decode(r, &req); err != nil {
		return errs.From(err)
	}

	{{.Recv}}, err := h.core.Update(ctx, id, {{.Pkg}}core.Update{{.Type}}{Name: req.Name, Description: req.Description})
	if err != nil {
		return errs.From(err)
	}
	return toResponse({{.Recv}}) // Response implements rest.ResponseEncoder
}

// delete removes a {{.Pkg}}.
func (h *Handler) delete(ctx context.Context, r *http.Request) rest.ResponseEncoder {
	id, err := uuid.Parse(r.PathValue("id"))
	if err != nil {
		return errs.Newf(errs.InvalidArgument, "invalid id %q", r.PathValue("id"))
	}

	if err := h.core.Delete(ctx, id); err != nil {
		return errs.From(err)
	}
	return nil // 204 No Content
}
