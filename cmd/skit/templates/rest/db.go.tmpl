// Package {{.Pkg}}db is the Postgres implementation of {{.Pkg}}.Store. It maps
// between the domain {{.Type}} and its database representation and uses the
// skit dbx helpers for query logging and error translation, following the
// SDK pg-store convention (inline const queries, a model.go row type, a
// map[string]any of named params + applyFilter for the dynamic WHERE).
package {{.Pkg}}db

import (
	"bytes"
	"context"
	"fmt"
	"strings"
	"time"

	"github.com/google/uuid"
	"github.com/jmoiron/sqlx"

	"github.com/assanoff/skit/logger"
	"github.com/assanoff/skit/order"
	"github.com/assanoff/skit/page"
	"github.com/assanoff/skit/dbx"
	"github.com/assanoff/skit/dbx/dialect"

	"{{.Module}}/core/{{.Pkg}}"
)

// Store implements {{.Pkg}}.Store against Postgres.
type Store struct {
	log     *logger.Logger
	db      sqlx.ExtContext
	dialect dialect.Dialect
}

// Option customizes a Store.
type Option func(*Store)

// WithDialect overrides the SQL dialect used to compose engine-specific SQL
// (pagination). Defaults to dialect.Postgres.
func WithDialect(d dialect.Dialect) Option {
	return func(s *Store) {
		s.dialect = d
	}
}

// NewStore builds a Store. Pass a *sqlx.DB for pool-backed use.
func NewStore(log *logger.Logger, db *sqlx.DB, opts ...Option) *Store {
	s := &Store{log: log, db: db, dialect: dialect.Postgres{}}
	for _, o := range opts {
		o(s)
	}
	return s
}

// Compile-time check that Store satisfies the domain contract.
var _ {{.Pkg}}.Store = (*Store)(nil)

// Create implements {{.Pkg}}.Store.
func (s *Store) Create(ctx context.Context, v {{.Pkg}}.{{.Type}}) error {
	const q = `
		INSERT INTO {{.Plural}} (id, name, description, created_at, updated_at)
		VALUES (:id, :name, :description, :created_at, :updated_at)`
	if err := dbx.NamedExecContext(ctx, s.log, s.db, q, toDB(v)); err != nil {
		return fmt.Errorf("create: %w", err)
	}
	return nil
}

// Update implements {{.Pkg}}.Store.
func (s *Store) Update(ctx context.Context, v {{.Pkg}}.{{.Type}}) error {
	const q = `
		UPDATE {{.Plural}}
		SET name = :name, description = :description, updated_at = :updated_at
		WHERE id = :id`
	if err := dbx.NamedExecContext(ctx, s.log, s.db, q, toDB(v)); err != nil {
		return fmt.Errorf("update: %w", err)
	}
	return nil
}

// Delete implements {{.Pkg}}.Store.
func (s *Store) Delete(ctx context.Context, id uuid.UUID) error {
	const q = `DELETE FROM {{.Plural}} WHERE id = :id`
	data := struct {
		ID string `db:"id"`
	}{ID: id.String()}
	if err := dbx.NamedExecContext(ctx, s.log, s.db, q, data); err != nil {
		return fmt.Errorf("delete: %w", err)
	}
	return nil
}

// QueryByID implements {{.Pkg}}.Store.
func (s *Store) QueryByID(ctx context.Context, id uuid.UUID) ({{.Pkg}}.{{.Type}}, error) {
	const q = `SELECT id, name, description, created_at, updated_at FROM {{.Plural}} WHERE id = :id`
	data := struct {
		ID string `db:"id"`
	}{ID: id.String()}

	var row db{{.Type}}
	if err := dbx.NamedQueryStruct(ctx, s.log, s.db, q, data, &row); err != nil {
		return {{.Pkg}}.{{.Type}}{}, fmt.Errorf("querybyid: %w", err)
	}
	return toCore(row), nil
}

// Count implements {{.Pkg}}.Store, honoring filter so a filtered total stays
// consistent with the filtered page.
func (s *Store) Count(ctx context.Context, filter {{.Pkg}}.QueryFilter) (int, error) {
	data := map[string]any{}
	buf := bytes.NewBufferString(`SELECT count(*) AS n FROM {{.Plural}}`)
	s.applyFilter(filter, data, buf)

	var row struct {
		N int `db:"n"`
	}
	if err := dbx.NamedQueryStruct(ctx, s.log, s.db, buf.String(), data, &row); err != nil {
		return 0, fmt.Errorf("count: %w", err)
	}
	return row.N, nil
}

// Query implements {{.Pkg}}.Store: one filtered, ordered page. The WHERE is built
// by applyFilter, the ORDER BY by orderByClause (allowlisted), and the pagination
// clause via the store's dialect, binding :offset and :rows_per_page below.
func (s *Store) Query(ctx context.Context, filter {{.Pkg}}.QueryFilter, by order.By, pg page.Page) ([]{{.Pkg}}.{{.Type}}, error) {
	clause, err := orderByClause(by)
	if err != nil {
		return nil, fmt.Errorf("query: %w", err)
	}

	data := map[string]any{
		"offset":        pg.Offset(),
		"rows_per_page": pg.RowsPerPage(),
	}

	buf := bytes.NewBufferString(`SELECT id, name, description, created_at, updated_at FROM {{.Plural}}`)
	s.applyFilter(filter, data, buf)
	buf.WriteString(clause)
	s.dialect.Paginate(buf)

	var rows []db{{.Type}}
	if err := dbx.NamedQuerySlice(ctx, s.log, s.db, buf.String(), data, &rows); err != nil {
		return nil, fmt.Errorf("query: %w", err)
	}
	return toCoreSlice(rows), nil
}

// QueryByCursor implements {{.Pkg}}.Store with keyset (cursor) pagination, honoring
// filter. It combines filter's predicates with the keyset boundary in one WHERE,
// fetches one extra row to detect a further page, trims it, and encodes the last
// row's (created_at, id) into the next token. Back it with a composite index on
// ({{.Plural}}) (created_at DESC, id DESC) so it stays O(limit) at any depth.
func (s *Store) QueryByCursor(ctx context.Context, filter {{.Pkg}}.QueryFilter, cur page.Cursor) ([]{{.Pkg}}.{{.Type}}, string, error) {
	key, err := cur.Key()
	if err != nil {
		return nil, "", fmt.Errorf("querybycursor: %w", err)
	}

	data := map[string]any{
		"limit": cur.Limit() + 1, // one extra row signals that a next page exists
	}

	// The keyset boundary is just one more predicate alongside filter's: bind its
	// params, then hand it to applyFilter as an extra so it lands in the same WHERE.
	var extra []string
	if key != "" {
		ts, id, err := decodeCursor(key)
		if err != nil {
			return nil, "", fmt.Errorf("querybycursor: %w", err)
		}
		data["after_ts"] = ts
		data["after_id"] = id
		// Rows strictly past the boundary in the (created_at DESC, id DESC) order;
		// the id tiebreaker makes the keyset total so paging never repeats a row.
		// CAST(... AS uuid) — not ::uuid — so sqlx's named-param parser doesn't
		// trip over the `::`.
		extra = append(extra, "(created_at, id) < (:after_ts, CAST(:after_id AS uuid))")
	}

	buf := bytes.NewBufferString(`SELECT id, name, description, created_at, updated_at FROM {{.Plural}}`)
	s.applyFilter(filter, data, buf, extra...)
	buf.WriteString(` ORDER BY created_at DESC, id DESC LIMIT :limit`)

	var rows []db{{.Type}}
	if err := dbx.NamedQuerySlice(ctx, s.log, s.db, buf.String(), data, &rows); err != nil {
		return nil, "", fmt.Errorf("querybycursor: %w", err)
	}

	var next string
	if len(rows) > cur.Limit() {
		rows = rows[:cur.Limit()]
		last := rows[len(rows)-1]
		next = page.EncodeCursor(encodeCursor(last.CreatedAt, last.ID))
	}
	return toCoreSlice(rows), next, nil
}

// The dynamic WHERE — applyFilter — lives in filter.go; keyset paging in
// QueryByCursor passes its boundary predicate to applyFilter as an extra so it
// is combined with the filter conditions under one WHERE.

// encodeCursor packs a {{.Pkg}}'s sort key (created_at, id) into the plain string
// that page.EncodeCursor turns into an opaque, URL-safe token.
func encodeCursor(createdAt time.Time, id uuid.UUID) string {
	return createdAt.UTC().Format(time.RFC3339Nano) + "|" + id.String()
}

// decodeCursor parses the key encodeCursor produced back into the boundary
// timestamp and id.
func decodeCursor(key string) (time.Time, string, error) {
	tsStr, idStr, ok := strings.Cut(key, "|")
	if !ok {
		return time.Time{}, "", fmt.Errorf("malformed cursor key %q", key)
	}
	ts, err := time.Parse(time.RFC3339Nano, tsStr)
	if err != nil {
		return time.Time{}, "", fmt.Errorf("malformed cursor timestamp %q: %w", tsStr, err)
	}
	return ts, idStr, nil
}
