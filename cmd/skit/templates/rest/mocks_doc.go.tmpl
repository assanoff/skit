// Package mocks holds generated mocks (moq) for the {{.Pkg}} interfaces — e.g.
// StoreMock for the Store interface, used by the API tests.
//
// The mocks are generated from the //go:generate directive on the interface;
// run `make generate` (or `go generate ./...`) to (re)generate them. This file
// only declares the package so the import path resolves before the first
// generation (keeping `go mod tidy` happy).
package mocks
