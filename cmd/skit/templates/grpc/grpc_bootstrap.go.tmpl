// This file is the gRPC bootstrap generated by `skit add grpc`. It assembles the
// gRPC server (the full skit interceptor chain + protovalidate request checks)
// and the gRPC-gateway REST proxy, and mounts the gateway + OpenAPI docs on the
// HTTP router. Wire it into server.go/routes.go as the next-steps describe.
package server

import (
	"context"
	"strings"

	"github.com/assanoff/skit/grpcgateway"
	"github.com/assanoff/skit/grpcserver"
	"github.com/assanoff/skit/logger"
	"github.com/assanoff/skit/metrics"
	"github.com/assanoff/skit/rest/router"

	"{{.Module}}/internal/app/deps"
	"{{.Module}}/internal/app/docs"
)

// buildGRPCServer assembles the gRPC server: the skit interceptor chain
// (recovery, trace, logging, metrics, error-map) plus protovalidate — every
// request message is checked against its .proto buf.validate rules before the
// handler runs, so handlers need not re-check them. The returned server is a
// worker.Runnable; append it to the supervised set in New when GRPC.Addr is set:
//
//	if opts.GRPC.Addr != "" {
//		runnables = append(runnables, buildGRPCServer(ctx, d, m, log))
//	}
func buildGRPCServer(ctx context.Context, d *deps.Deps, m *metrics.Metrics, log *logger.Logger) *grpcserver.Server {
	gs := grpcserver.New(log, grpcserver.Config{
		Addr:             d.Opts.GRPC.Addr,
		EnableReflection: d.Opts.GRPC.Reflection,
	},
		grpcserver.WithTracer(d.Tracer(ctx)),
		grpcserver.WithMetrics(m.Registry),
		grpcserver.WithProtoValidate(),
	)
	installGRPC(ctx, gs, d)
	return gs
}

// installGRPC registers every gRPC feature handler. `skit add grpc <entity>`
// adds one line here per entity — each handler implements grpcserver.Service.
// Build the handler from its Core the same way the REST wiring does, e.g.:
//
//	gs.Install({{.Pkg}}grpc.New(d.{{.Type}}Core(ctx)))
func installGRPC(ctx context.Context, gs *grpcserver.Server, d *deps.Deps) {
	_, _, _ = ctx, gs, d
	// gs.Install({{.Pkg}}grpc.New(d.{{.Type}}Core(ctx)))
}

// mountGRPCGateway mounts the gRPC-gateway REST proxy (/v1/...) and, when
// GRPC.Docs is set, the OpenAPI spec (/openapi.json) + Swagger UI (/docs) on r.
// Call it from Install (in routes.go):
//
//	mountGRPCGateway(ctx, r, d)
//
// The gateway dials the local gRPC server, so it is a no-op unless GRPC.Gateway
// is set and GRPC.Addr points at the running server.
func mountGRPCGateway(ctx context.Context, r *router.Router, d *deps.Deps) {
	if !d.Opts.GRPC.Gateway || d.Opts.GRPC.Addr == "" {
		return
	}
	gw, err := grpcgateway.New(ctx, grpcgateway.Config{
		Endpoint: gatewayEndpoint(d.Opts.GRPC.Addr),
	}, gatewayRegistrars()...)
	if err != nil {
		d.Logger.Error(ctx, "grpc gateway: build failed", "err", err)
		return
	}
	r.Handle("/v1/", gw) // the generated google.api.http rules live under /v1
	if d.Opts.GRPC.Docs {
		r.Handle("GET /openapi.json", docs.SpecHandler())
		r.Handle("GET /docs", docs.UIHandler("/openapi.json"))
	}
}

// gatewayRegistrars lists the generated gateway handlers to mount. `skit add
// grpc <entity>` adds one per entity (import the entity's genv1 package):
//
//	{{.Pkg}}v1.Register{{.Type}}ServiceHandler,
func gatewayRegistrars() []grpcgateway.HandlerRegistrar {
	return []grpcgateway.HandlerRegistrar{
		// {{.Pkg}}v1.Register{{.Type}}ServiceHandler,
	}
}

// gatewayEndpoint turns a listen address into a dial target: ":9090" ->
// "localhost:9090" (a client cannot dial a bare-port address).
func gatewayEndpoint(addr string) string {
	if strings.HasPrefix(addr, ":") {
		return "localhost" + addr
	}
	return addr
}
