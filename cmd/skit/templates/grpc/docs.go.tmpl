// Package docs serves the generated OpenAPI (swagger) document and a Swagger UI.
// The spec, apidocs.swagger.json, is produced by `make proto` (the buf openapiv2
// plugin) into this package directory and embedded into the binary, so the docs
// are served from the running service with no external files.
package docs

import (
	_ "embed"
	"net/http"
	"strings"
)

//go:embed apidocs.swagger.json
var spec []byte

// SpecHandler serves the raw OpenAPI v2 (swagger) document as JSON.
func SpecHandler() http.Handler {
	return http.HandlerFunc(func(w http.ResponseWriter, _ *http.Request) {
		w.Header().Set("Content-Type", "application/json")
		_, _ = w.Write(spec)
	})
}

// UIHandler serves a Swagger UI page that loads the spec from specURL. The UI
// assets (JS/CSS) are pulled from a CDN; vendor them under this package and
// embed them too if you need a fully offline docs page.
func UIHandler(specURL string) http.Handler {
	page := strings.ReplaceAll(swaggerUIPage, "__SPEC_URL__", specURL)
	body := []byte(page)
	return http.HandlerFunc(func(w http.ResponseWriter, _ *http.Request) {
		w.Header().Set("Content-Type", "text/html; charset=utf-8")
		_, _ = w.Write(body)
	})
}

const swaggerUIPage = `<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>API documentation</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swagger-ui-dist@5/swagger-ui.css">
</head>
<body>
  <div id="swagger-ui"></div>
  <script src="https://cdn.jsdelivr.net/npm/swagger-ui-dist@5/swagger-ui-bundle.js"></script>
  <script>
    window.onload = function () {
      window.ui = SwaggerUIBundle({ url: "__SPEC_URL__", dom_id: "#swagger-ui" });
    };
  </script>
</body>
</html>
`
