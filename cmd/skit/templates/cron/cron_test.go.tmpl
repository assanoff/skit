{{if .Locked}}
// stubLocker is a lock.Locker double: ok controls whether the lock is granted.
type stubLocker struct{ ok bool }

func (s stubLocker) TryLock(context.Context, string, time.Duration) (lock.Release, bool, error) {
	return func() {}, s.ok, nil
}

func TestGuardedSkipsWhenLockHeld(t *testing.T) {
	is := is.New(t)
	log := logger.New(io.Discard, logger.Config{Service: "test", Level: logger.LevelError})

	c := New(log, stubLocker{ok: false})      // lock always held elsewhere
	is.NoErr(c.guarded(context.Background()))  // skips cleanly, no error
}
