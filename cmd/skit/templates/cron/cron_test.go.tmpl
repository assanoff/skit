func newTestCron() *Cron {
	log := logger.New(io.Discard, logger.Config{Service: "test", Level: logger.LevelError})
	return New(log{{if .Locked}}, stubLocker{ok: true}{{end}})
}

func TestRun(t *testing.T) {
	is := is.New(t)
	is.NoErr(newTestCron().run(context.Background())) // one invocation succeeds
}

func TestSchedulerBuilds(t *testing.T) {
	is := is.New(t)
	s, err := newTestCron().Scheduler()
	is.NoErr(err)          // schedule spec is valid
	is.Equal(s.Name(), Name)
