package {{.Pkg}}

import (
	"encoding/json"
	"testing"

	"github.com/google/uuid"
	"github.com/matryer/is"

	"github.com/assanoff/skit/outbox"
)

// TestRegister checks the event registers cleanly into a fresh outbox Registry.
func TestRegister(t *testing.T) {
	is := is.New(t)
	is.NoErr(Register(outbox.NewRegistry())) // route registered without error
}

// TestPayloadRoundTrips checks the payload survives a JSON round-trip — the
// shape the relay marshals into the CloudEvents `data`.
func TestPayloadRoundTrips(t *testing.T) {
	is := is.New(t)

	in := {{.Type}}{ID: uuid.New()}
	b, err := json.Marshal(in)
	is.NoErr(err)

	var out {{.Type}}
	is.NoErr(json.Unmarshal(b, &out))
	is.Equal(out.ID, in.ID) // id preserved across marshal/unmarshal
}
